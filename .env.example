# ============================================================================
# DenunciaBot — Variables de entorno
# ----------------------------------------------------------------------------
# COPIA este archivo como `.env` y completa los valores.
# NUNCA commitees el archivo .env real.
# Genera los secretos con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Genera la Fernet key con:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================================

# ---------------------------------------------------------------------------
# Aplicación
# ---------------------------------------------------------------------------
APP_NAME=DenunciaBot
APP_ENV=development              # development | staging | production
APP_HOST=127.0.0.1               # En producción se queda en localhost; el TLS lo gestiona el equipo de seguridad
APP_PORT=8000
APP_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
APP_DEBUG=false                  # NUNCA true en producción

# ---------------------------------------------------------------------------
# Seguridad — Cifrado y hashing
# ---------------------------------------------------------------------------
# Clave Fernet (44 caracteres base64). Genera con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Usada para cifrar institucion_denunciada, descripcion_hechos, personas_involucradas
# y nombres originales de archivos de evidencia.
DENUNCIABOT_MASTER_KEY=

# Pepper para hash de teléfonos (secreto adicional al SHA-256, evita ataques de fuerza bruta).
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
DENUNCIABOT_PHONE_PEPPER=

# ---------------------------------------------------------------------------
# Base de datos — PostgreSQL 16
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://denunciabot:CAMBIAR@localhost:5432/denunciabot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false              # true solo para debug en desarrollo

# ---------------------------------------------------------------------------
# Redis 7 — Sesiones activas (TTL automático) y cola Dramatiq
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_SESIONES_DB=0              # Base 0 para sesiones de conversación
REDIS_DRAMATIQ_DB=1              # Base 1 para cola de tareas async

# ---------------------------------------------------------------------------
# Meta Cloud API — WhatsApp Business
# ---------------------------------------------------------------------------
META_API_VERSION=v18.0
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=                 # Para validar firma X-Hub-Signature-256
META_VERIFY_TOKEN=               # Token arbitrario que ponemos también en el dashboard de Meta

# ---------------------------------------------------------------------------
# SMTP — Notificación al cierre de la denuncia
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.sercop.gob.ec
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=denunciabot@sercop.gob.ec
SMTP_FROM_NAME=DenunciaBot — Integridad Pública
SMTP_TO=integridad@secretaria.gob.ec    # Destinatario institucional de las denuncias
SMTP_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Evidencias — Archivos adjuntos
# ---------------------------------------------------------------------------
EVIDENCIAS_DIR=/var/lib/denunciabot/evidencias    # Local: usar ./evidencias
EVIDENCIAS_MAX_SIZE_MB=10
EVIDENCIAS_MAX_COUNT=5
EVIDENCIAS_MIME_PERMITIDOS=application/pdf,image/jpeg,image/png

# ---------------------------------------------------------------------------
# ClamAV — Escaneo antivirus de evidencias (opcional pero recomendado)
# ---------------------------------------------------------------------------
CLAMAV_ENABLED=false             # true en producción una vez instalado clamd
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Conversación — Tiempos y límites del flujo
# ---------------------------------------------------------------------------
SESION_TIMEOUT_AVISO_SECONDS=240     # 4 min → aviso de inactividad
SESION_TIMEOUT_CIERRE_SECONDS=300    # 5 min → cierre y descarte de sesión
MAX_INTENTOS_VALIDACION=3            # Reintentos por estado antes de reformular

# ---------------------------------------------------------------------------
# Códigos públicos de alerta
# ---------------------------------------------------------------------------
CODIGO_PREFIJO=ALR
# Alfabeto sin caracteres ambiguos (sin 0/O/1/I/l): 32 chars × 6 = ~1B combinaciones
CODIGO_ALFABETO=23456789ABCDEFGHJKLMNPQRSTUVWXYZ
CODIGO_LONGITUD=6

# ---------------------------------------------------------------------------
# Rate limiting (slowapi) — protección del webhook
# ---------------------------------------------------------------------------
RATE_LIMIT_WEBHOOK=120/minute

# ---------------------------------------------------------------------------
# Panel admin (vacío = deshabilitado)
# ---------------------------------------------------------------------------
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_TOKEN=
ADMIN_COOKIE_NAME=denunciabot_admin
ADMIN_COOKIE_MAX_AGE=28800   # 8 horas en segundos    # Margen amplio: Meta puede mandar ráfagas

# ---------------------------------------------------------------------------
# Observabilidad
# ---------------------------------------------------------------------------
LOG_FORMAT=json                  # json en producción, console en desarrollo
LOG_FILE=                        # Vacío = stdout (recomendado con systemd/journald)
